<figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line"><span class="meta">#<span class="keyword">include</span> <span class="string">&lt;bits/stdc++.h&gt;</span></span></span><br><span class="line"></span><br><span class="line"><span class="keyword">using</span> <span class="keyword">namespace</span> std;</span><br><span class="line"></span><br><span class="line"><span class="type">const</span> <span class="type">int</span> N = <span class="number">1.5e5</span> + <span class="number">10</span>, M = <span class="number">3e5</span> + <span class="number">10</span>;</span><br><span class="line"><span class="type">int</span> n, Q, A, age[N], h[N], e[M], w[M], ne[M], idx;</span><br><span class="line"><span class="function"><span class="keyword">inline</span> <span class="type">void</span> <span class="title">add</span><span class="params">(<span class="type">int</span> a, <span class="type">int</span> b, <span class="type">int</span> c)</span> </span>&#123;e[idx] = b, ne[idx] = h[a], w[idx] = c, h[a] = idx ++; &#125;</span><br><span class="line"></span><br><span class="line"><span class="keyword">namespace</span> Tree_Split &#123;</span><br><span class="line">    <span class="type">int</span> fa[N], siz[N], son[N], dep[N], Dep[N], top[N];</span><br><span class="line">    <span class="function"><span class="type">void</span> <span class="title">dfs</span><span class="params">(<span class="type">int</span> u, <span class="type">int</span> f)</span> </span>&#123;</span><br><span class="line">        fa[u] = f, siz[u] = <span class="number">1</span>, son[u] = <span class="number">0</span>, dep[u] = dep[f] + <span class="number">1</span>;</span><br><span class="line">        <span class="keyword">for</span>(<span class="type">int</span> i = h[u]; i != <span class="number">-1</span>; i = ne[i]) &#123;</span><br><span class="line">            <span class="type">int</span> v = e[i]; <span class="keyword">if</span>(v == f) <span class="keyword">continue</span>;</span><br><span class="line">            Dep[v] = Dep[u] + w[i], <span class="built_in">dfs</span>(v, u), siz[u] += siz[v];</span><br><span class="line">            <span class="keyword">if</span>(siz[v] &gt; siz[son[u]]) son[u] = v;</span><br><span class="line">        &#125;</span><br><span class="line">    &#125;</span><br><span class="line">    <span class="function"><span class="type">void</span> <span class="title">hld</span><span class="params">(<span class="type">int</span> u, <span class="type">int</span> topf)</span> </span>&#123;</span><br><span class="line">        top[u] = topf; <span class="keyword">if</span>(!son[u]) <span class="keyword">return</span>;</span><br><span class="line">        <span class="built_in">hld</span>(son[u], topf);</span><br><span class="line">        <span class="keyword">for</span>(<span class="type">int</span> i = h[u]; i != <span class="number">-1</span>; i = ne[i]) &#123;</span><br><span class="line">            <span class="type">int</span> v = e[i]; <span class="keyword">if</span>(v == fa[u] || v == son[u]) <span class="keyword">continue</span>;</span><br><span class="line">            <span class="built_in">hld</span>(v, v);</span><br><span class="line">        &#125;</span><br><span class="line">    &#125;</span><br><span class="line">    <span class="function"><span class="keyword">inline</span> <span class="type">void</span> <span class="title">init</span><span class="params">()</span> </span>&#123;<span class="built_in">dfs</span>(<span class="number">1</span>, <span class="number">0</span>), <span class="built_in">hld</span>(<span class="number">1</span>, <span class="number">1</span>); &#125;</span><br><span class="line">    <span class="function"><span class="keyword">inline</span> <span class="type">int</span> <span class="title">lca</span><span class="params">(<span class="type">int</span> u, <span class="type">int</span> v)</span> </span>&#123;</span><br><span class="line">        <span class="keyword">while</span>(top[u] != top[v]) &#123;</span><br><span class="line">            <span class="keyword">if</span>(dep[top[u]] &lt; dep[top[v]]) <span class="built_in">swap</span>(u, v);</span><br><span class="line">            u = fa[top[u]];</span><br><span class="line">        &#125;</span><br><span class="line">        <span class="keyword">return</span> dep[u] &lt; dep[v] ? u : v;</span><br><span class="line">    &#125;</span><br><span class="line">    <span class="function"><span class="keyword">inline</span> <span class="type">int</span> <span class="title">dist</span><span class="params">(<span class="type">int</span> u, <span class="type">int</span> v)</span> </span>&#123;<span class="keyword">return</span> Dep[u] + Dep[v] - <span class="number">2</span> * Dep[<span class="built_in">lca</span>(u, v)]; &#125;</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line"><span class="keyword">namespace</span> DFZ &#123;</span><br><span class="line">    <span class="type">bool</span> vis[N]; <span class="type">int</span> fa[N]; vector&lt;<span class="type">int</span>&gt; G[N], subtree[N];</span><br><span class="line">    <span class="keyword">struct</span> <span class="title class_">node</span> &#123;</span><br><span class="line">        <span class="type">int</span> age = <span class="number">-1</span>, cnt = <span class="number">0</span>; <span class="type">long</span> <span class="type">long</span> dst = <span class="number">0</span>;</span><br><span class="line">        <span class="built_in">node</span>() &#123;&#125;</span><br><span class="line">        <span class="built_in">node</span>(<span class="type">int</span> a, <span class="type">int</span> c, <span class="type">long</span> <span class="type">long</span> d) : <span class="built_in">age</span>(a), <span class="built_in">cnt</span>(c), <span class="built_in">dst</span>(d) &#123;&#125;</span><br><span class="line">        <span class="type">bool</span> <span class="keyword">operator</span> &lt; (<span class="type">const</span> node &amp;rhs) <span class="type">const</span> &#123;<span class="keyword">return</span> age &lt; rhs.age; &#125;</span><br><span class="line">    &#125;;</span><br><span class="line">    vector&lt;node&gt; ans[N][<span class="number">3</span>], ans_all[N];</span><br><span class="line">    <span class="type">int</span> siz[N], maxsz[N], Size, root;</span><br><span class="line">    <span class="function"><span class="type">void</span> <span class="title">calc_siz</span><span class="params">(<span class="type">int</span> u, <span class="type">int</span> f)</span> </span>&#123;</span><br><span class="line">        siz[u] = <span class="number">1</span>, maxsz[u] = <span class="number">0</span>;</span><br><span class="line">        <span class="keyword">for</span>(<span class="type">int</span> i = h[u]; i != <span class="number">-1</span>; i = ne[i]) &#123;</span><br><span class="line">            <span class="type">int</span> v = e[i]; <span class="keyword">if</span>(vis[v] || v == f) <span class="keyword">continue</span>;</span><br><span class="line">            <span class="built_in">calc_siz</span>(v, u), siz[u] += siz[v]; maxsz[u] = <span class="built_in">max</span>(maxsz[u], siz[v]);</span><br><span class="line">        &#125;</span><br><span class="line">        <span class="keyword">if</span>(!f) Size = siz[u];</span><br><span class="line">    &#125;</span><br><span class="line">    <span class="function"><span class="type">void</span> <span class="title">calc_root</span><span class="params">(<span class="type">int</span> u, <span class="type">int</span> f)</span> </span>&#123;</span><br><span class="line">        maxsz[u] = <span class="built_in">max</span>(maxsz[u], Size - siz[u]);</span><br><span class="line">        <span class="keyword">if</span>(maxsz[u] &lt; maxsz[root]) root = u;</span><br><span class="line">        <span class="keyword">for</span>(<span class="type">int</span> i = h[u]; i != <span class="number">-1</span>; i = ne[i]) &#123;</span><br><span class="line">            <span class="type">int</span> v = e[i]; <span class="keyword">if</span>(vis[v] || v == f) <span class="keyword">continue</span>;</span><br><span class="line">            <span class="built_in">calc_root</span>(v, u);</span><br><span class="line">        &#125;</span><br><span class="line">    &#125;</span><br><span class="line">    <span class="function"><span class="keyword">inline</span> <span class="type">void</span> <span class="title">calc_root</span><span class="params">(<span class="type">int</span> u)</span> </span>&#123;<span class="built_in">calc_siz</span>(u, <span class="number">0</span>), root = u, <span class="built_in">calc_root</span>(u, <span class="number">0</span>); &#125;</span><br><span class="line">    <span class="function"><span class="type">void</span> <span class="title">solve</span><span class="params">(<span class="type">int</span> u)</span> </span>&#123;</span><br><span class="line">        vis[u] = <span class="literal">true</span>;</span><br><span class="line">        <span class="keyword">for</span>(<span class="type">int</span> i = h[u]; i != <span class="number">-1</span>; i = ne[i]) &#123;</span><br><span class="line">            <span class="type">int</span> v = e[i]; <span class="keyword">if</span>(vis[v]) <span class="keyword">continue</span>;</span><br><span class="line">            <span class="built_in">calc_root</span>(v); v = root, fa[v] = u, G[u].<span class="built_in">emplace_back</span>(v), <span class="built_in">solve</span>(v);</span><br><span class="line">        &#125;</span><br><span class="line">        subtree[u].<span class="built_in">emplace_back</span>(u);</span><br><span class="line">        <span class="keyword">for</span>(<span class="keyword">auto</span> v : G[u]) <span class="keyword">for</span>(<span class="keyword">auto</span> x : subtree[v]) subtree[u].<span class="built_in">emplace_back</span>(x);</span><br><span class="line">        <span class="built_in">assert</span>(G[u].<span class="built_in">size</span>() &lt; <span class="number">4</span>);</span><br><span class="line">        <span class="keyword">for</span>(<span class="type">int</span> i = <span class="number">0</span>; i &lt; G[u].<span class="built_in">size</span>(); i ++) &#123;</span><br><span class="line">            <span class="comment">// calc ans[u][i]</span></span><br><span class="line">            map&lt;<span class="type">int</span>, pair&lt;<span class="type">int</span>, <span class="type">long</span> <span class="type">long</span>&gt;&gt; Map; Map[age[u]].first ++;</span><br><span class="line">            <span class="keyword">for</span>(<span class="type">int</span> j = <span class="number">0</span>; j &lt; G[u].<span class="built_in">size</span>(); j ++) <span class="keyword">if</span>(j != i) &#123;</span><br><span class="line">                <span class="keyword">for</span>(<span class="keyword">auto</span> v : subtree[G[u][j]]) Map[age[v]].first ++, Map[age[v]].second += Tree_Split::<span class="built_in">dist</span>(u, v);</span><br><span class="line">            &#125;</span><br><span class="line">            ans[u][i].<span class="built_in">resize</span>(Map.<span class="built_in">size</span>() + <span class="number">1</span>); ans[u][i][<span class="number">0</span>].age = <span class="number">-1</span>, ans[u][i][<span class="number">0</span>].cnt = <span class="number">0</span>, ans[u][i][<span class="number">0</span>].dst = <span class="number">0</span>; <span class="type">int</span> id = <span class="number">1</span>;</span><br><span class="line">            <span class="keyword">for</span>(<span class="keyword">auto</span> ppr : Map) ans[u][i][id] = <span class="built_in">node</span>(ppr.first, ppr.second.first + ans[u][i][id - <span class="number">1</span>].cnt, ppr.second.second + ans[u][i][id - <span class="number">1</span>].dst), id ++;</span><br><span class="line">        &#125;</span><br><span class="line">        <span class="comment">// calc ans_all[u]</span></span><br><span class="line">        map&lt;<span class="type">int</span>, pair&lt;<span class="type">int</span>, <span class="type">long</span> <span class="type">long</span>&gt;&gt; Map;</span><br><span class="line">        <span class="keyword">for</span>(<span class="keyword">auto</span> v : subtree[u]) Map[age[v]].first ++, Map[age[v]].second += Tree_Split::<span class="built_in">dist</span>(u, v);</span><br><span class="line">        ans_all[u].<span class="built_in">resize</span>(Map.<span class="built_in">size</span>() + <span class="number">1</span>); ans_all[u][<span class="number">0</span>].age = <span class="number">-1</span>, ans_all[u][<span class="number">0</span>].cnt = <span class="number">0</span>, ans_all[u][<span class="number">0</span>].dst = <span class="number">0</span>; <span class="type">int</span> id = <span class="number">1</span>;</span><br><span class="line">        <span class="keyword">for</span>(<span class="keyword">auto</span> ppr : Map) ans_all[u][id] = <span class="built_in">node</span>(ppr.first, ppr.second.first + ans_all[u][id - <span class="number">1</span>].cnt, ppr.second.second + ans_all[u][id - <span class="number">1</span>].dst), id ++;</span><br><span class="line">    &#125;</span><br><span class="line">    <span class="function"><span class="keyword">inline</span> <span class="type">void</span> <span class="title">init</span><span class="params">()</span> </span>&#123;</span><br><span class="line">        <span class="built_in">memset</span>(vis, <span class="literal">false</span>, <span class="keyword">sizeof</span> vis);</span><br><span class="line">        <span class="built_in">calc_root</span>(<span class="number">1</span>); <span class="type">int</span> Root = root;</span><br><span class="line">        <span class="built_in">solve</span>(root);</span><br><span class="line">    &#125;</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line"><span class="function"><span class="keyword">inline</span> <span class="type">void</span> <span class="title">init</span><span class="params">()</span> </span>&#123;</span><br><span class="line">    Tree_Split::<span class="built_in">init</span>();</span><br><span class="line">    DFZ::<span class="built_in">init</span>();</span><br><span class="line">&#125;</span><br><span class="line"><span class="function"><span class="keyword">inline</span> pair&lt;<span class="type">int</span>, <span class="type">long</span> <span class="type">long</span>&gt; <span class="title">ask</span><span class="params">(vector&lt;DFZ::node&gt; &amp;vec, <span class="type">int</span> bound)</span> </span>&#123;</span><br><span class="line">    <span class="keyword">auto</span> &amp;res = vec[--<span class="built_in">upper_bound</span>(vec.<span class="built_in">begin</span>(), vec.<span class="built_in">end</span>(), DFZ::<span class="built_in">node</span>(bound, <span class="number">0</span>, <span class="number">0</span>)) - vec.<span class="built_in">begin</span>()];</span><br><span class="line">    <span class="keyword">return</span> &#123;res.cnt, res.dst&#125;;</span><br><span class="line">&#125;</span><br><span class="line"><span class="function"><span class="keyword">inline</span> <span class="type">long</span> <span class="type">long</span> <span class="title">calc</span><span class="params">(<span class="type">int</span> u, <span class="type">int</span> bound)</span> </span>&#123; <span class="type">int</span> source = u;</span><br><span class="line">    <span class="type">long</span> <span class="type">long</span> ans = <span class="built_in">ask</span>(DFZ::ans_all[u], bound).second;</span><br><span class="line">    <span class="keyword">for</span>(<span class="type">int</span> f = DFZ::fa[u]; f; f = DFZ::fa[f], u = DFZ::fa[u]) &#123;</span><br><span class="line">        <span class="type">int</span> id = <span class="number">-1</span>;</span><br><span class="line">        <span class="keyword">for</span>(<span class="type">int</span> i = <span class="number">0</span>; i &lt; DFZ::G[f].<span class="built_in">size</span>(); i ++) <span class="keyword">if</span>(DFZ::G[f][i] == u) &#123;id = i; <span class="keyword">break</span>; &#125;</span><br><span class="line">        <span class="built_in">assert</span>(id != <span class="number">-1</span>);</span><br><span class="line">        <span class="keyword">auto</span> res = <span class="built_in">ask</span>(DFZ::ans[f][id], bound);</span><br><span class="line">        ans += res.second + <span class="number">1ll</span> * res.first * Tree_Split::<span class="built_in">dist</span>(source, f);</span><br><span class="line">    &#125;</span><br><span class="line">    <span class="keyword">return</span> ans;</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line"><span class="function"><span class="type">int</span> <span class="title">main</span><span class="params">()</span> </span>&#123;</span><br><span class="line">    ios::<span class="built_in">sync_with_stdio</span>(<span class="literal">false</span>), cin.<span class="built_in">tie</span>(<span class="number">0</span>);</span><br><span class="line">    <span class="built_in">memset</span>(h, <span class="number">-1</span>, <span class="keyword">sizeof</span> h);</span><br><span class="line"></span><br><span class="line">    cin &gt;&gt; n &gt;&gt; Q &gt;&gt; A;</span><br><span class="line">    <span class="keyword">for</span>(<span class="type">int</span> i = <span class="number">1</span>; i &lt;= n; i ++) cin &gt;&gt; age[i];</span><br><span class="line">    <span class="keyword">for</span>(<span class="type">int</span> i = <span class="number">1</span>; i &lt; n; i ++) &#123;</span><br><span class="line">        <span class="type">int</span> a, b, c; cin &gt;&gt; a &gt;&gt; b &gt;&gt; c;</span><br><span class="line">        <span class="built_in">add</span>(a, b, c), <span class="built_in">add</span>(b, a, c);</span><br><span class="line">    &#125;</span><br><span class="line">    <span class="built_in">init</span>();</span><br><span class="line"></span><br><span class="line">    <span class="type">long</span> <span class="type">long</span> last_ans = <span class="number">0</span>;</span><br><span class="line">    <span class="keyword">while</span>(Q --) &#123;</span><br><span class="line">        <span class="type">long</span> <span class="type">long</span> u, a, b, l, r; cin &gt;&gt; u &gt;&gt; a &gt;&gt; b; (a += last_ans) %= A, (b += last_ans) %= A;</span><br><span class="line">        l = <span class="built_in">min</span>(a, b), r = <span class="built_in">max</span>(a, b);</span><br><span class="line">        cout &lt;&lt; (last_ans = <span class="built_in">calc</span>(u, r) - (l == <span class="number">0</span> ? <span class="number">0</span> : <span class="built_in">calc</span>(u, l - <span class="number">1</span>))) &lt;&lt; <span class="string">&#x27;\n&#x27;</span>;</span><br><span class="line">    &#125;</span><br><span class="line"></span><br><span class="line">    <span class="keyword">return</span> <span class="number">0</span>;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>

